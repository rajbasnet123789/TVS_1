# ==============================================================================
# POULTRY MONITORING SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and modify the values for your environment.
# Run 'openssl rand -hex 32' to generate secure random keys for passwords/secrets.

# ------------------------------------------------------------------------------
# 1. CORE NETWORK & DOMAIN SETUP
# ------------------------------------------------------------------------------
# Domain (Set to your registered domain, e.g., poultry.yourdomain.com for HTTPS via Caddy)
# For local testing, use 'localhost'.
DOMAIN=localhost

# Tailscale (Optional: Generate auth key at https://login.tailscale.com/admin/settings/keys)
# Reusable + pre-approved keys are recommended for servers; ephemeral for farm nodes.
TAILSCALE_AUTH_KEY=<change-me>

# ------------------------------------------------------------------------------
# 2. DATABASE CREDENTIALS (USE SECURE RANDOM PASSWORDS IN PRODUCTION)
# ------------------------------------------------------------------------------
# PostgreSQL Database Password
POSTGRES_PASSWORD=<change-me>

# InfluxDB Time-Series Credentials
INFLUX_PASSWORD=<change-me>
INFLUX_TOKEN=<change-me>
INFLUX_ORG=poultry
INFLUX_BUCKET=detections

# Media Storage (Local filesystem path on server host/volume)
MEDIA_ROOT=/var/opt/poultry/media

# ------------------------------------------------------------------------------
# 3. FRIGATE NVR CONFIGURATION
# ------------------------------------------------------------------------------
FRIGATE_API_URL=http://frigate:5000
FRIGATE_GO2RTC_URL=http://frigate:1984
# RTSP password for camera streams managed by Frigate
FRIGATE_RTSP_PASSWORD=<change-me>

# ------------------------------------------------------------------------------
# 4. MQTT (MOSQUITTO) BROKER DETAILS
# ------------------------------------------------------------------------------
MQTT_BROKER=mosquitto
MQTT_PORT=1883
# MQTT username and password (generate password using mosquitto_passwd)
MQTT_USERNAME=frigate
MQTT_PASSWORD=<change-me>

# ------------------------------------------------------------------------------
# 5. SECURITY & AUTHENTICATION (CRITICAL FOR PRODUCTION)
# ------------------------------------------------------------------------------
# Default Super Admin Password (Use a strong password for initial admin@poultry.farm login)
DEFAULT_ADMIN_PASSWORD=<change-me>

# JWT Signing Secret (Generate using: openssl rand -hex 32)
JWT_SECRET=<change-me>
JWT_ALGORITHM=HS256

# Database Encryption Key and Salt (Generate using: openssl rand -hex 32)
ENCRYPTION_KEY=<change-me>
ENCRYPTION_SALT=<change-me>

# Token Expirations
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie Security (MUST be set to 'true' in production over HTTPS)
COOKIES_SECURE=false

# ------------------------------------------------------------------------------
# 6. CORS & FRONTEND API ENDPOINTS
# ------------------------------------------------------------------------------
# CORS Allowed Origins (Comma-separated. For prod, set to https://poultry.yourdomain.com)
CORS_ORIGINS=http://localhost:3000

# Frontend builds endpoints (For prod, set to https://poultry.yourdomain.com)
VITE_API_URL=http://localhost:8000
VITE_FRIGATE_GO2RTC_URL=http://localhost:1984

# ------------------------------------------------------------------------------
# 7. AI INFRASTRUCTURE
# ------------------------------------------------------------------------------
MODEL_HEALTH_PATH=AI_MODEL/best.pt
MODEL_HEALTH_CHECKSUM_SHA256=<change-me>

# ------------------------------------------------------------------------------
# 8. OBSERVABILITY, MONITORING & BACKUPS
# ------------------------------------------------------------------------------
# Sentry DSN (Optional error tracking: e.g., https://...@...ingest.sentry.io/...)
SENTRY_DSN=

# Logging Level (Use 'INFO' or 'DEBUG' for local dev, 'WARNING' for production)
LOG_LEVEL=INFO
DB_ECHO=false
DEBUG=true
ENVIRONMENT=development

# Automated Backups (stored inside poultry_backups volume)
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14

# ------------------------------------------------------------------------------
# 9. OPTIONAL SYSTEM INTEGRATIONS
# ------------------------------------------------------------------------------
# NVR ONVIF auto-discovery credentials
NVR_HOST=
NVR_USERNAME=
NVR_PASSWORD=

# Google Single Sign-On (OAuth credentials)
GOOGLE_CLIENT_ID=
