# Domain (set to your real domain for production HTTPS via Caddy)
DOMAIN=your-domain.com

# Tailscale (generate auth key at https://login.tailscale.com/admin/settings/keys)
# Reusable + pre-approved keys are recommended for servers; ephemeral for farm nodes
TAILSCALE_AUTH_KEY=<change-me>

# Database
POSTGRES_PASSWORD=<change-me>

# Redis
REDIS_URL=redis://redis:6379/0

# InfluxDB
INFLUX_TOKEN=<change-me>
INFLUX_ORG=poultry
INFLUX_BUCKET=detections

# Media storage (local filesystem — server has 900GB disk at /dev/vda2)
MEDIA_ROOT=/var/opt/poultry/media

# Frigate (internal Docker network URLs)
FRIGATE_API_URL=http://frigate:5000
FRIGATE_GO2RTC_URL=http://frigate:1984

# MQTT (Mosquitto)
MQTT_USERNAME=<change-me>
MQTT_PASSWORD=<change-me>
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# AI Model (health classifier)
MODEL_HEALTH_PATH=AI_MODEL/best.pt
MODEL_HEALTH_CHECKSUM_SHA256=<change-me>

# Sentry (error tracking — optional, leave blank to disable)
SENTRY_DSN=

# Auth
DEFAULT_ADMIN_PASSWORD=<change-me>
JWT_SECRET=<change-me>
JWT_ALGORITHM=HS256
ENCRYPTION_KEY=<change-me>
ENCRYPTION_SALT=<change-me>

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend (overrides for Docker)
VITE_API_URL=http://localhost:8000
VITE_FRIGATE_GO2RTC_URL=http://localhost:1984

# Detection
CAMERA_PROCESS_INTERVAL=3

# Cookies security (set to true in production over HTTPS)
COOKIES_SECURE=false

# Logging
LOG_LEVEL=INFO
DB_ECHO=false

# Backup (scheduled daily via backup container, stored locally)
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=14

# NVR Configuration (for ONVIF camera scanning)
NVR_HOST=<change-me>
NVR_USERNAME=<change-me>
NVR_PASSWORD=<change-me>
